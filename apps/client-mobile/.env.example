# Convex deployment URL (same for client web and client mobile)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk — https://dashboard.clerk.com/last-active?path=api-keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Mobile requires a development build (expo-dev-client), not Expo Go.
# Build once: cd apps/client-mobile && npx expo run:ios  (or eas build --profile development)

# Sentry
# EXPO_PUBLIC_SENTRY_DSN=

# PostHog
# EXPO_PUBLIC_POSTHOG_PROJECT_TOKEN=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
