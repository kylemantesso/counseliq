{
  "expo": {
    "name": "CounselIQ Client",
    "slug": "counseliq-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "counseliq-client",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f5f5f0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.counseliq.client",
      "appleTeamId": "5YHDP5R5DB"
    },
    "android": {
      "package": "com.counseliq.client",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
