{
  "name": "@counseliq/client-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client",
    "build": "expo export --platform ios --platform android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:dev": "eas build --profile development",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "workflow:develop": "eas workflow:run develop-deploy",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "echo 'Mobile typecheck skipped (Expo 54 + React 19 vs react-native types). Run: cd apps/client-mobile && npx tsc --noEmit to see status.'"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@counseliq/client": "*",
    "@counseliq/ui": "*",
    "@sentry/react-native": "~7.2.0",
    "convex": "^1.39.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.4",
    "nativewind": "^5.0.0-preview.4",
    "posthog-react-native": "^4.50.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "0.5.1",
    "semver": "^7.8.0",
    "solito": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.2"
  }
}
