# Convex deployment URL (same for web and mobile)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk — https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Set the same Frontend API URL on the Convex deployment (Dashboard → Settings → Environment Variables)
# CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Optional app origin for email links
# NEXT_PUBLIC_APP_WEB_ORIGIN=http://localhost:3000

# Sentry — https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=   # required for client; also used by server/edge if SENTRY_DSN is unset
# SENTRY_DSN=               # optional server-only override
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# PostHog — https://posthog.com
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
