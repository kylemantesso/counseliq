{
  "name": "counseliq",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "audio:campus": "node scripts/campus-audio.mjs",
    "build": "turbo run build",
    "build:admin:web": "npm run build --workspace=@counseliq/admin-web",
    "build:client:mobile": "npm run build --workspace=@counseliq/client-mobile",
    "build:client:mobile:dev": "npm run build:dev --workspace=@counseliq/client-mobile",
    "build:client:web": "npm run build --workspace=@counseliq/client-web",
    "build:web": "npm run build:admin:web",
    "convex:deploy": "convex deploy",
    "convex:dev": "convex dev",
    "deploy": "node scripts/init.mjs --deploy",
    "dev": "npm run dev:admin:web",
    "dev:admin:web": "npm run dev --workspace=@counseliq/admin-web",
    "dev:all": "concurrently \"npm run convex:dev\" \"turbo run dev --parallel --filter=@counseliq/admin-web --filter=@counseliq/client-web --filter=@counseliq/client-mobile\"",
    "dev:client:mobile": "npm run dev --workspace=@counseliq/client-mobile",
    "dev:client:web": "npm run dev --workspace=@counseliq/client-web",
    "dev:renderer": "npm run dev --workspace=@counseliq/renderer",
    "dev:stack": "node scripts/dev-local-stack.mjs",
    "dev:web": "npm run dev:admin:web",
    "env:sync:convex-email": "node scripts/sync-convex-email-env.mjs",
    "eval": "node scripts/eval.mjs",
    "eval:assets": "node scripts/eval-assets.mjs",
    "eval:compile": "node scripts/eval-compile.mjs",
    "init": "node scripts/init.mjs",
    "init:existing": "node scripts/init.mjs --use-existing",
    "lint": "turbo run lint",
    "prompts:build": "node scripts/build-prompts.mjs",
    "test": "turbo run test && npm run test:convex",
    "test:convex": "vitest run --config vitest.config.convex.ts",
    "typecheck": "turbo run typecheck",
    "walkthrough": "node scripts/walkthrough.mjs",
    "walkthrough:local": "CONVEX_DEPLOYMENT=anonymous:anonymous-counsel-iq node scripts/walkthrough.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.5",
    "@convex-dev/workflow": "^0.4.4",
    "@convex-dev/workpool": "^0.4.7",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "convex-helpers": "^0.1.119",
    "expo-server-sdk": "^6.1.0",
    "react-email": "^6.6.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "concurrently": "^9.1.2",
    "convex": "^1.39.1",
    "convex-test": "^0.0.54",
    "turbo": "^2.5.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "^15.15.5",
    "expo-constants": "~18.0.13",
    "lightningcss": "1.30.1"
  }
}
